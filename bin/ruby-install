#!/usr/bin/env bash

if (( $# < 1 )); then
    version=$(cat .ruby-version);
    if [[ -z "$version" ]]; then
        echoerr "No version given";
    else
        ruby-install $version
    fi
else
    mkdir -p ~/.rubies;
    for version in "$@"; do
        echodo ruby-build $version "$HOME/.rubies/$version";
    done
    resource
fi
